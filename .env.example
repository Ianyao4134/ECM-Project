# Required: DeepSeek API key
DEEPSEEK_API_KEY=

# Optional (Python backend / app.config)
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_TIMEOUT_S=60
# ECM_PROMPTS_DIR=prompts
# ECM_DATA_DIR=data

# Set to 1 to skip copying seed/data into ECM_DATA_DIR and skip sample analytics rows (empty install).
# ECM_DISABLE_SEED=

# Optional (Express proxy in server/index.js)
# PORT=8787

# Production gateway (server/prod.js): listen address (default 0.0.0.0 in Docker)
# HOST=0.0.0.0
# Port for the public Node gateway (cloud platforms often set PORT automatically)
# PORT=8080
# Python ECM backend URL inside the same machine/container (do not change in Docker)
# ECM_BACKEND_URL=http://127.0.0.1:9000

# Owner-only audit console (optional). If unset, /ecm/admin/* returns 503.
# Open frontend at /audit-console and send this value as header X-ECM-Admin-Secret (stored in sessionStorage).
# ECM_ADMIN_SECRET=your-long-random-secret
